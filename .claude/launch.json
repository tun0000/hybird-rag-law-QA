{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "python", "scripts/run_api.py"],
      "port": 8000
    },
    {
      "name": "ui",
      "runtimeExecutable": "uv",
      "runtimeArgs": [
        "run", "streamlit", "run", "ui/app.py",
        "--server.address", "0.0.0.0",
        "--server.port", "8501",
        "--server.headless", "true",
        "--browser.gatherUsageStats", "false"
      ],
      "port": 8501
    }
  ]
}
