# ── LLM ──────────────────────────────────────────────
# Provider: anthropic | openai | gemini | ollama
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
# Leave empty to use the provider's default model (see src/rag/config.py)
GENERATION_MODEL=
JUDGE_MODEL=

# ── Embedding / Reranker ─────────────────────────────
# auto | cuda | cpu
DEVICE=auto

# ── Qdrant ───────────────────────────────────────────
# local = in-process file mode (no Docker needed) | server = docker-compose Qdrant
QDRANT_MODE=local
QDRANT_PATH=storage/qdrant
QDRANT_URL=http://localhost:6333
