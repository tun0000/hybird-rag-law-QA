# Secrets — never commit API keys
.env

# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
.pytest_cache/

# Corpus & indexes (reproducible via scripts/) — keep the small sample set
data/*
!data/sample/
storage/

# Evaluation run artifacts (config snapshots + per-question traces)
eval/runs/

# Model caches
.cache/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# Streamlit local settings (may contain machine-specific paths)
.streamlit/

# Claude Code runtime state (machine/session-specific, not project config)
.claude/scheduled_tasks.lock
